{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "include": ["src/**/*", "tests/**/*", "playwright/**/*", "*.config.mjs"],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
